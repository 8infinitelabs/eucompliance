{
  "name": "@eucompliance/accessibility-bridge",
  "version": "0.1.0",
  "description": "Maps EU AI Act Article 16(l) obligations to EN 301 549 accessibility requirements",
  "license": "EUPL-1.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@eucompliance/ai-act-classifier": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "eu-ai-act",
    "eaa",
    "en-301-549",
    "wcag",
    "accessibility",
    "article-16l",
    "compliance"
  ]
}
